{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:packages && pnpm --filter @couch/realtime build && pnpm --filter @couch/web build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "fluid": true,
  "routes": [
    {
      "src": "^/api/realtime/(.*)$",
      "dest": "/api/realtime/[...path]?...path=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}

{
  "name": "@couch/trebuchet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sim": {
      "types": "./dist/sim.d.ts",
      "import": "./dist/sim.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx tests/sim.test.ts && vitest run tests/engine.test.ts"
  },
  "dependencies": {
    "@couch/game-runtime": "workspace:*",
    "@couch/types": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}

{
  "name": "@couch/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-sdk.mjs && vite --host 0.0.0.0",
    "build": "node scripts/copy-sdk.mjs && tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"@couch/web uses Playwright e2e tests from the repo root\""
  },
  "dependencies": {
    "@couch/game-runtime": "workspace:*",
    "@couch/game-sdk": "workspace:*",
    "@couch/trebuchet": "workspace:*",
    "@couch/types": "workspace:*",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "phaser": "^3.90.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "socket.io-client": "^4.8.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}

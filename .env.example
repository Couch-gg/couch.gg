PORT=4100
VITE_REALTIME_URL=
VITE_REALTIME_API_PREFIX=
VITE_REALTIME_SOCKET_PATH=
CLIENT_ORIGIN=
API_PREFIX=/api
SOCKET_PATH=/socket.io
REDIS_URL=
# Admin key for the published-games admin surface (takedown/restore/feature and
# GET /api/admin/games). Sent as the x-admin-key header, compared constant-time.
# When unset, every /api/admin/games* route returns 503 (admin surface disabled).
ADMIN_KEY=
# Ops escape hatch to register external (iframe-hosted) games before the durable
# registry exists: a JSON array of creator-supplied manifests. Each entry is
# validated and stamped origin=external/status=published; invalid entries are
# skipped. http localhost entryUrls are allowed only in local dev (not on Vercel).
# Example: [{"id":"tap-race","title":"Tap Race",...,"entryUrl":"https://...","sdkProtocol":1}]
EXTERNAL_GAMES_JSON=
